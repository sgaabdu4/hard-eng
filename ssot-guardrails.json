{
  "scannerRegistry": [
    {
      "path": "scripts/check-generated-assets.mjs",
      "owners": ["generated-assets.json"]
    },
    {
      "path": "scripts/check-hard-eng-full-repo.mjs",
      "owners": ["tests/hard-eng-full-repo-gate.test.mjs", "README.md"]
    },
    {
      "path": "scripts/check-hard-eng-artifacts.mjs",
      "owners": ["tests/hard-eng-artifacts.test.mjs", "README.md"]
    },
    {
      "path": "scripts/check-hard-eng-write-safety.mjs",
      "owners": ["tests/hard-eng-write-safety.test.mjs", "README.md"]
    },
    {
      "path": "scripts/check-markdown-hygiene.mjs",
      "owners": ["AGENTS.md"]
    },
    {
      "path": "scripts/check-project-context-gates.mjs",
      "owners": ["PRODUCT.md", "DESIGN.md", "docs/design/tokens.css"]
    },
    {
      "path": "scripts/check-project-naming.mjs",
      "owners": ["ssot-guardrails.json"]
    },
    {
      "path": "scripts/check-project-quality-gates.mjs",
      "owners": ["scripts/install.sh"]
    },
    {
      "path": "scripts/check-no-mistakes-projects.mjs",
      "owners": ["tests/no-mistakes-projects.test.mjs", "README.md"]
    },
    {
      "path": "scripts/check-ssot-guardrails.mjs",
      "owners": ["ssot-guardrails.json"]
    },
    {
      "path": "scripts/check-vendor-skill-integrity.mjs",
      "owners": ["AGENTS.md", "skills/workflow-help/references/route-map.md"]
    }
  ],
  "patternRules": [
    {
      "id": "workflow-doc-design-tokens",
      "pattern": "oklch\\(",
      "include": ["docs/**/*.html", "README.md", "PRODUCT.md", "DESIGN.md"],
      "owners": ["docs/design/tokens.css"],
      "message": "Workflow document color literals must use docs/design/tokens.css variables"
    },
    {
      "id": "no-curl-pipe-shell",
      "pattern": "curl[^\\n|]*\\|\\s*(sh|bash)",
      "include": ["scripts/**/*.sh", "README.md"],
      "owners": ["scripts/setup.sh", "README.md"],
      "message": "External installers must not use curl pipe shell; download first and gate execution behind explicit opt-in or verification"
    }
  ]
}
