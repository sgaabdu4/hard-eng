#!/usr/bin/env bash
# Managed by hard-eng installer.
set -euo pipefail

ROOT="${HARD_ENG_ROOT:-$HOME/.agents}"
PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.npm-global/bin:$HOME/.local/bin:$HOME/flutter/bin:$HOME/.pub-cache/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
export PATH
mode="update"

case "${1:-}" in
  ""|--update)
    mode="update"
    ;;
  --repair|--manual|--after-manual-update)
    mode="repair"
    export HARD_ENG_SKIP_SUBMODULE_INIT="${HARD_ENG_SKIP_SUBMODULE_INIT:-1}"
    ;;
  -h|--help)
    cat <<'USAGE'
Usage:
  codex-update-stack
      Update Codex, context-mode, and codebase-memory-mcp, then repair local setup.

  codex-update-stack --repair
      Repair local setup after a manual package or Codex app update.
USAGE
    exit 0
    ;;
  *)
    echo "Usage: codex-update-stack [--update|--repair]" >&2
    exit 2
    ;;
esac

trusted_workstation() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|y|Y) return 0 ;;
    *) return 1 ;;
  esac
}

load_installer_consent() {
  local plist="$HOME/Library/LaunchAgents/dev.hard-eng.codex-watchdog.plist" consent_env assignment
  [[ -f "$plist" ]] || return 0
  consent_env="$(mktemp)"
  if python3 - "$plist" >"$consent_env" <<'PY'
import os
import plistlib
import sys
from pathlib import Path

keys = [
    "HARD_ENG_TRUSTED_WORKSTATION",
    "HARD_ENG_SKIP_PREREQ_INSTALL",
    "HARD_ENG_SKIP_NPM_INSTALL",
    "HARD_ENG_SKIP_MCP_CONFIG",
    "HARD_ENG_SKIP_SHELL_PATH_UPDATE",
    "HARD_ENG_SKIP_WATCHDOG",
    "HARD_ENG_SKIP_SUBMODULE_INIT",
]
truthy = {"1", "true", "yes", "y"}
try:
    data = plistlib.loads(Path(sys.argv[1]).read_bytes())
except Exception:
    data = {}
plist_env = data.get("EnvironmentVariables") or {}
for key in keys:
    if os.environ.get(key):
        continue
    if str(plist_env.get(key, "")).lower() in truthy:
        print(f"{key}=1")
PY
  then
    while IFS= read -r assignment; do
      [[ -n "$assignment" ]] && export "$assignment"
    done <"$consent_env"
  fi
  rm -f "$consent_env"
}

load_installer_consent

if ! trusted_workstation "${HARD_ENG_TRUSTED_WORKSTATION:-0}"; then
  echo "codex-update-stack is trusted-workstation-only; set HARD_ENG_TRUSTED_WORKSTATION=1." >&2
  exit 1
fi

if [[ ! -x "$ROOT/scripts/install.sh" ]]; then
  echo "Missing installer: $ROOT/scripts/install.sh" >&2
  exit 1
fi

if [[ "$mode" == "repair" ]]; then
  echo "Repairing Codex stack after manual update from $ROOT"
else
  echo "Updating Codex stack from $ROOT"
fi
"$ROOT/scripts/install.sh"

if [[ ! -x "$HOME/.codex/bin/codex-cleanup" ]]; then
  echo "Missing cleanup command: $HOME/.codex/bin/codex-cleanup" >&2
  exit 1
fi

"$HOME/.codex/bin/codex-cleanup"

python3 <<'PY'
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path


def fail(message):
    print(message, file=sys.stderr)
    raise SystemExit(1)


for command in ("codex", "context-mode", "codebase-memory-mcp"):
    path = shutil.which(command)
    if not path:
        fail(f"Missing command on PATH: {command}")
    print(f"{command}={path}")

doctor = subprocess.run(
    ["codex", "doctor", "--json"],
    text=True,
    capture_output=True,
    timeout=60,
)
if doctor.returncode != 0:
    fail((doctor.stderr or doctor.stdout or "codex doctor failed").strip())

try:
    data = json.loads(doctor.stdout)
except json.JSONDecodeError as exc:
    fail(f"codex doctor returned invalid JSON: {exc}")

overall = data.get("overallStatus")
if overall not in ("ok", "warning"):
    fail(f"codex doctor overallStatus={overall!r}")

checks = data.get("checks") or data.get("issues") or {}
required_ok = ("config.load", "mcp.config", "state.paths")
bad_required = []
for check_name in required_ok:
    check = checks.get(check_name)
    if isinstance(check, dict) and check.get("status") != "ok":
        bad_required.append(f"{check_name}={check.get('status')}")
if bad_required:
    fail("codex doctor required checks failed: " + ", ".join(bad_required))

sandbox = checks.get("sandbox.helpers") or {}
details = sandbox.get("details") or {}
filesystem = details.get("filesystem sandbox")
approval = details.get("approval policy")
if filesystem != "unrestricted":
    fail(f"filesystem sandbox is not unrestricted: {filesystem!r}")
if approval != "Never":
    fail(f"approval policy is not Never: {approval!r}")

prefix = subprocess.run(
    ["npm", "prefix", "-g"],
    text=True,
    capture_output=True,
    timeout=30,
)
if prefix.returncode != 0:
    fail((prefix.stderr or "npm prefix -g failed").strip())

expected_cbm = Path(prefix.stdout.strip()) / "bin" / "codebase-memory-mcp"
shadow_cbm = Path.home() / ".local" / "bin" / "codebase-memory-mcp"
if shadow_cbm.exists() or shadow_cbm.is_symlink():
    if not shadow_cbm.is_symlink():
        fail(f"CBM shadow is not a symlink: {shadow_cbm}")
    target = Path(os.readlink(shadow_cbm))
    if target != expected_cbm:
        fail(f"CBM shadow points at {target}, expected {expected_cbm}")

print("codex doctor ok: filesystem sandbox=unrestricted approval=Never")
if overall == "warning":
    warnings = [
        f"{name}={check.get('status')}"
        for name, check in checks.items()
        if isinstance(check, dict) and check.get("status") != "ok"
    ]
    print("codex doctor warnings: " + ", ".join(warnings))
codex_cbm = Path.home() / ".codex" / "bin" / "codebase-memory-mcp"
if not codex_cbm.exists() or not os.access(codex_cbm, os.X_OK):
    fail(f"Missing executable Codex CBM command: {codex_cbm}")
print(f"CBM shadow ok: {shadow_cbm} -> {expected_cbm}")
print(f"Codex CBM command ok: {codex_cbm}")

hooks_path = Path.home() / ".codex" / "hooks.json"
try:
    hooks = json.loads(hooks_path.read_text())
except Exception as exc:
    fail(f"Failed to read Codex hooks config: {exc}")
hook_events = hooks.get("hooks") or {}
if "SessionStart" in hook_events:
    fail("Codex SessionStart hook must stay disabled.")
if "context-mode hook" in json.dumps(hook_events):
    fail("Codex context-mode hooks must stay stripped.")
print("codex hooks ok: SessionStart disabled context-mode hooks absent")
PY

CBM_MCP_PROBE_TIMEOUT_MS="${CBM_MCP_PROBE_TIMEOUT_MS:-30000}" \
  node "$ROOT/scripts/probe-codebase-memory-mcp.mjs" "$HOME/.codex/bin/codebase-memory-mcp"
HARD_ENG_ROOT="$ROOT" "$ROOT/codex/bin/codex-context-mode-health"

python3 <<'PY'
import os
import subprocess
import sys
from pathlib import Path


def fail(message):
    print(message, file=sys.stderr)
    raise SystemExit(1)

health = Path.home() / ".codex" / "bin" / "codex-health"
if health.exists() and os.access(health, os.X_OK):
    result = subprocess.run(
        [str(health)],
        text=True,
        capture_output=True,
        timeout=90,
    )
    if result.returncode != 0:
        fail((result.stderr or result.stdout or "codex-health failed").strip())
    interesting_prefixes = (
        "overallStatus=",
        "codexVersion=",
        "mcpServers=",
        "global_state ",
        "rollout_rows ",
        "plugin_manifests ",
        "cbm_shadow ",
        "duplicate_mcp_children ",
        "cbm_projects ",
        "codebase-memory-mcp=",
        "context-mode command ok:",
        "context-mode no-hooks config ok:",
        "context-mode MCP probe ok:",
    )
    print("codex-health summary:")
    for line in result.stdout.splitlines():
        if line.startswith(interesting_prefixes):
            print(line)
PY

if [[ "$mode" == "repair" ]]; then
  echo "Codex stack repair complete. Restart active Codex sessions to refresh MCP processes."
else
  echo "Codex stack update complete. Restart active Codex sessions to refresh MCP processes."
fi
