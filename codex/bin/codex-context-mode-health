#!/usr/bin/env bash
# Managed by hard-eng installer.
set -euo pipefail

ROOT="${HARD_ENG_ROOT:-$HOME/.agents}"
CONTEXT_MODE_BIN="$(command -v context-mode || true)"

if [[ -z "$CONTEXT_MODE_BIN" ]]; then
  echo "Missing command on PATH: context-mode" >&2
  exit 1
fi

CODEX_CONFIG_PATH="$HOME/.codex/config.toml" CONTEXT_MODE_BIN="$CONTEXT_MODE_BIN" python3 <<'PY'
from pathlib import Path
import json
import os
import re
import sys


def fail(message):
    print(message, file=sys.stderr)
    raise SystemExit(1)


config_path = Path(os.environ["CODEX_CONFIG_PATH"])
context_mode_bin = os.environ["CONTEXT_MODE_BIN"]
text = config_path.read_text() if config_path.exists() else ""

if not re.search(r"^\s*\[mcp_servers\.context-mode\]\s*$", text, re.M):
    fail("context-mode MCP config missing from ~/.codex/config.toml")
if not re.search(r'^\s*command\s*=\s*"context-mode"\s*$', text, re.M):
    fail("context-mode MCP command must stay command = \"context-mode\"")
if not re.search(r"^\s*\[mcp_servers\.context-mode\.env\]\s*$", text, re.M):
    fail("context-mode MCP env section missing from ~/.codex/config.toml")
if not re.search(r'^\s*CONTEXT_MODE_PLATFORM\s*=\s*"codex"\s*$', text, re.M):
    fail("context-mode MCP must declare CONTEXT_MODE_PLATFORM = \"codex\"")
expected_dir = str(Path.home() / ".codex" / "context-mode")
if not re.search(rf'^\s*CONTEXT_MODE_DIR\s*=\s*"{re.escape(expected_dir)}"\s*$', text, re.M):
    fail(f"context-mode MCP must declare CONTEXT_MODE_DIR = \"{expected_dir}\"")

hooks_path = Path.home() / ".codex" / "hooks.json"
try:
    hooks = json.loads(hooks_path.read_text())
except Exception as exc:
    fail(f"Failed to read Codex hooks config: {exc}")

hook_events = hooks.get("hooks") or {}
serialized = json.dumps(hook_events)
if "SessionStart" in hook_events:
    fail("Codex SessionStart hook must stay disabled.")
if "context-mode hook" in serialized:
    fail("Codex context-mode hooks must stay stripped.")

print(f"context-mode command ok: {context_mode_bin}")
print("context-mode no-hooks config ok: MCP registered; storage pinned to ~/.codex/context-mode; Codex context-mode hooks absent")
PY

CONTEXT_MODE_DIR="$HOME/.codex/context-mode" node "$ROOT/scripts/probe-context-mode-mcp.mjs" "$CONTEXT_MODE_BIN"
