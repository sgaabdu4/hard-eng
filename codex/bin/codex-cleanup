#!/usr/bin/env python3
# Managed by hard-eng installer.
import json
import os
import signal
import sqlite3
import subprocess
import sys
import time
from pathlib import Path


HOME = Path(os.environ.get("HOME", "")).expanduser()
CODEX_HOME = HOME / ".codex"
CHECK_ONLY = "--check" in sys.argv
REPAIR_GLOBAL_STATE = os.environ.get("CODEX_CLEANUP_REPAIR_GLOBAL_STATE") == "1"
DELETE_STALE_THREAD_ROWS = os.environ.get("CODEX_CLEANUP_DELETE_STALE_THREAD_ROWS") == "1"


def emit(event, **fields):
    parts = [event]
    for key, value in fields.items():
        parts.append(f"{key}={value}")
    print(" ".join(parts))


def read_json(path):
    try:
        return json.loads(path.read_text())
    except Exception:
        return None


def write_json(path, data):
    if CHECK_ONLY:
        return
    path.write_text(json.dumps(data, separators=(",", ":")) + "\n")


def thread_ids():
    db = CODEX_HOME / "state_5.sqlite"
    if not db.exists():
        return set()
    con = sqlite3.connect(db)
    try:
        return {row[0] for row in con.execute("select id from threads")}
    finally:
        con.close()


def prune_list(value, valid):
    if not isinstance(value, list):
        return value, 0
    kept = [item for item in value if not isinstance(item, str) or item in valid]
    return kept, len(value) - len(kept)


def prune_mapping(value, valid):
    if not isinstance(value, dict):
        return value, 0
    kept = {key: val for key, val in value.items() if key in valid}
    return kept, len(value) - len(kept)


def repair_global_state(valid):
    if not REPAIR_GLOBAL_STATE:
        emit("global_state", status="skip_disabled", check=CHECK_ONLY)
        return

    path = CODEX_HOME / ".codex-global-state.json"
    data = read_json(path)
    if not isinstance(data, dict):
        emit("global_state", status="skip")
        return
    atoms = data.get("electron-persisted-atom-state")
    if not isinstance(atoms, dict):
        emit("global_state", status="skip")
        return

    removed = 0
    for key in ("pinned-thread-ids", "projectless-thread-ids"):
        atoms[key], count = prune_list(atoms.get(key), valid)
        removed += count

    unread = atoms.get("unread-thread-ids-by-host-v1")
    if isinstance(unread, dict):
        for host, ids in list(unread.items()):
            unread[host], count = prune_list(ids, valid)
            removed += count

    for key in (
        "thread-workspace-root-hints",
        "thread-projectless-output-directories",
        "heartbeat-thread-permissions-by-id",
        "queued-follow-ups",
    ):
        atoms[key], count = prune_mapping(atoms.get(key), valid)
        removed += count

    if removed:
        write_json(path, data)
    emit("global_state", removed=removed, check=CHECK_ONLY)


def stale_thread_rows(max_age_seconds=86400):
    db = CODEX_HOME / "state_5.sqlite"
    if not db.exists():
        return []
    cutoff_ms = int((time.time() - max_age_seconds) * 1000)
    con = sqlite3.connect(db)
    con.row_factory = sqlite3.Row
    try:
        rows = con.execute(
            "select id, rollout_path, updated_at_ms, created_at_ms from threads "
            "where rollout_path is not null and rollout_path != ''"
        ).fetchall()
    finally:
        con.close()

    stale = []
    for row in rows:
        rollout = Path(row["rollout_path"]).expanduser()
        updated = row["updated_at_ms"] or row["created_at_ms"] or 0
        if not rollout.exists() and int(updated) < cutoff_ms:
            stale.append(row["id"])
    return stale


def repair_rollout_rows():
    stale = stale_thread_rows()
    if not stale:
        emit("rollout_rows", removed=0, check=CHECK_ONLY)
        return
    if CHECK_ONLY or not DELETE_STALE_THREAD_ROWS:
        emit(
            "rollout_rows",
            removable=len(stale),
            check=CHECK_ONLY,
            delete_enabled=DELETE_STALE_THREAD_ROWS,
        )
        return

    db = CODEX_HOME / "state_5.sqlite"
    con = sqlite3.connect(db)
    try:
        con.executemany(
            "delete from thread_dynamic_tools where thread_id = ?",
            [(item,) for item in stale],
        )
        con.executemany(
            "delete from thread_spawn_edges where parent_thread_id = ? or child_thread_id = ?",
            [(item, item) for item in stale],
        )
        con.executemany(
            "delete from agent_job_items where assigned_thread_id = ?",
            [(item,) for item in stale],
        )
        con.executemany("delete from threads where id = ?", [(item,) for item in stale])
        con.commit()
    finally:
        con.close()
    emit("rollout_rows", removed=len(stale), check=False)


def plugin_manifest_paths():
    roots = [
        CODEX_HOME / "plugins/cache",
        HOME / ".cache/codex-runtimes/codex-primary-runtime/plugins",
    ]
    for root in roots:
        if root.exists():
            yield from root.rglob(".codex-plugin/plugin.json")


def repair_plugin_manifests():
    changed = 0
    for path in plugin_manifest_paths():
        data = read_json(path)
        if not isinstance(data, dict):
            continue
        interface = data.get("interface")
        if not isinstance(interface, dict):
            continue
        touched = False
        prompts = interface.get("defaultPrompt")
        if isinstance(prompts, list) and len(prompts) > 3:
            interface["defaultPrompt"] = prompts[:3]
            touched = True
        for key in ("icon", "icon_small", "icon_large"):
            value = interface.get(key)
            if isinstance(value, str) and ".." in Path(value).parts:
                del interface[key]
                touched = True
        if touched:
            changed += 1
            if not CHECK_ONLY:
                path.write_text(json.dumps(data, indent=2) + "\n")
    emit("plugin_manifests", changed=changed, check=CHECK_ONLY)


def ps_rows():
    out = subprocess.run(
        ["ps", "-axo", "pid=,ppid=,command="],
        capture_output=True,
        text=True,
        check=False,
    )
    rows = []
    for line in out.stdout.splitlines():
        parts = line.strip().split(None, 2)
        if len(parts) != 3:
            continue
        pid, ppid, command = parts
        if pid.isdigit() and ppid.isdigit():
            rows.append((int(pid), int(ppid), command))
    return rows


def ps_group_rows():
    out = subprocess.run(
        ["ps", "-axo", "pid=,ppid=,pgid=,etime=,command="],
        capture_output=True,
        text=True,
        check=False,
    )
    rows = []
    for line in out.stdout.splitlines():
        parts = line.strip().split(None, 4)
        if len(parts) != 5:
            continue
        pid, ppid, pgid, etime, command = parts
        if pid.isdigit() and ppid.isdigit() and pgid.isdigit():
            rows.append((int(pid), int(ppid), int(pgid), etime, command))
    return rows


def is_codex_app_server(command):
    return (
        "/Applications/Codex.app/Contents/Resources/codex app-server" in command
        or command.endswith("/codex app-server --analytics-default-enabled")
        or "codex app-server --analytics-default-enabled" in command
    )


def duplicate_mcp_kind(command):
    if command == "codebase-memory-mcp" or command.endswith("/codebase-memory-mcp"):
        return "codebase-memory-mcp"
    if command.startswith("node ") and "/context-mode" in command:
        return "context-mode"
    if command.endswith("/node_repl"):
        return "node_repl"
    if "SkyComputerUseClient" in command and " mcp" in command:
        return "computer-use"
    return None


def trim_duplicate_mcp_children(limit=None):
    if limit is None:
        limit = int(os.environ.get("CODEX_CLEANUP_MCP_CHILD_LIMIT", "4"))
    rows = ps_rows()
    app_servers = {pid for pid, _, command in rows if is_codex_app_server(command)}
    children = {}
    for pid, ppid, command in rows:
        kind = duplicate_mcp_kind(command)
        if ppid in app_servers and kind:
            children.setdefault((ppid, kind), []).append((pid, command))

    killed = []
    for _, items in children.items():
        if len(items) <= limit:
            continue
        for pid, _ in sorted(items, key=lambda item: item[0])[: len(items) - limit]:
            killed.append(pid)
            if not CHECK_ONLY:
                try:
                    os.kill(pid, signal.SIGTERM)
                except OSError:
                    pass
    emit("duplicate_mcp_children", killed=len(killed), pids=",".join(map(str, killed)) or "none", check=CHECK_ONLY)


def parse_etime_seconds(value):
    days = 0
    time_value = value
    if "-" in value:
        day_text, time_value = value.split("-", 1)
        if not day_text.isdigit():
            return None
        days = int(day_text)
    fields = time_value.split(":")
    if len(fields) == 3:
        hours, minutes, seconds = fields
    elif len(fields) == 2:
        hours = "0"
        minutes, seconds = fields
    else:
        return None
    if not (hours.isdigit() and minutes.isdigit() and seconds.isdigit()):
        return None
    return (((days * 24) + int(hours)) * 60 + int(minutes)) * 60 + int(seconds)


def configured_stale_cli_roots():
    raw = os.environ.get("CODEX_CLEANUP_STALE_CLI_CWDS", "").strip()
    if not raw:
        return []
    roots = []
    for item in raw.replace(",", os.pathsep).split(os.pathsep):
        item = item.strip()
        if not item:
            continue
        roots.append(Path(item).expanduser().resolve(strict=False))
    return roots


def cwd_for_pid(pid):
    try:
        out = subprocess.run(
            ["lsof", "-a", "-p", str(pid), "-d", "cwd", "-Fn"],
            capture_output=True,
            text=True,
            check=False,
            timeout=5,
        )
    except Exception:
        return None
    for line in out.stdout.splitlines():
        if line.startswith("n"):
            return Path(line[1:]).expanduser().resolve(strict=False)
    return None


def path_is_under(path, roots):
    for root in roots:
        try:
            path.relative_to(root)
            return True
        except ValueError:
            continue
    return False


def is_codex_cli_root(command):
    if " app-server" in command or "/Codex (Service).app/" in command or "/Codex (Renderer).app/" in command:
        return False
    return (
        (command.startswith("node ") and "/bin/codex" in command)
        or ("/node_modules/@openai/codex/" in command and "/bin/codex " in command)
        or "/Applications/Codex.app/Contents/Resources/codex exec " in command
    )


def cleanup_stale_codex_cli_groups():
    roots = configured_stale_cli_roots()
    if not roots:
        emit("stale_codex_cli_groups", status="skip_unconfigured", check=CHECK_ONLY)
        return
    max_age = int(os.environ.get("CODEX_CLEANUP_STALE_CLI_MAX_AGE_SECONDS", "21600"))
    current_pgid = os.getpgrp()
    candidates = []
    for pid, _, pgid, etime, command in ps_group_rows():
        if pid != pgid or pgid == current_pgid or not is_codex_cli_root(command):
            continue
        age = parse_etime_seconds(etime)
        if age is None or age < max_age:
            continue
        cwd = cwd_for_pid(pid)
        if cwd is None or not path_is_under(cwd, roots):
            continue
        candidates.append((pgid, age, str(cwd)))

    killed = []
    if not CHECK_ONLY:
        for pgid, _, _ in candidates:
            try:
                os.killpg(pgid, signal.SIGTERM)
                killed.append(pgid)
            except OSError:
                pass
    emit(
        "stale_codex_cli_groups",
        candidates=len(candidates),
        killed=len(killed),
        pgids=",".join(str(item[0]) for item in candidates) or "none",
        max_age_seconds=max_age,
        check=CHECK_ONLY,
    )


def cbm_bin():
    for path in (
        HOME / ".local/bin/codebase-memory-mcp",
        HOME / ".npm-global/bin/codebase-memory-mcp",
    ):
        if path.exists():
            return str(path)
    return "codebase-memory-mcp"


def repair_cbm_shadow_binary():
    npm_prefix = subprocess.run(
        ["npm", "prefix", "-g"],
        capture_output=True,
        text=True,
        check=False,
        timeout=20,
    )
    npm_root = subprocess.run(
        ["npm", "root", "-g"],
        capture_output=True,
        text=True,
        check=False,
        timeout=20,
    )
    if npm_prefix.returncode != 0 or npm_root.returncode != 0:
        emit("cbm_shadow", status="npm_path_failed")
        return
    npm_bin = Path(npm_prefix.stdout.strip()) / "bin/codebase-memory-mcp"
    if not npm_bin.exists():
        npm_bin = Path(npm_root.stdout.strip()) / "codebase-memory-mcp/bin.js"
    shadow = HOME / ".local/bin/codebase-memory-mcp"
    removed_backups = 0

    for backup in shadow.parent.glob("codebase-memory-mcp.backup.*"):
        removed_backups += 1
        if not CHECK_ONLY:
            backup.unlink(missing_ok=True)

    linked = False
    if npm_bin.exists() and shadow.exists():
        target = None
        if shadow.is_symlink():
            try:
                target = shadow.resolve()
            except OSError:
                target = None
        if target != npm_bin:
            linked = True
            if not CHECK_ONLY:
                shadow.unlink(missing_ok=True)
                shadow.symlink_to(npm_bin)

    emit("cbm_shadow", linked=linked, removed_backups=removed_backups, check=CHECK_ONLY)


def parse_json_output(text):
    start = text.find("{")
    end = text.rfind("}")
    if start == -1 or end == -1 or end <= start:
        return None
    try:
        return json.loads(text[start : end + 1])
    except Exception:
        return None


def should_run(name, interval):
    stamp = CODEX_HOME / "logs" / f"codex-cleanup-{name}.stamp"
    if CHECK_ONLY:
        return True
    try:
        last = float(stamp.read_text())
    except Exception:
        last = 0
    if time.time() - last < interval:
        return False
    stamp.parent.mkdir(parents=True, exist_ok=True)
    stamp.write_text(str(time.time()))
    return True


def clean_cbm_temp_projects():
    interval = int(os.environ.get("CODEX_CLEANUP_CBM_INTERVAL_SECONDS", "3600"))
    if not should_run("cbm", interval):
        emit("cbm_projects", status="skip_interval")
        return
    out = subprocess.run(
        [cbm_bin(), "cli", "list_projects"],
        capture_output=True,
        text=True,
        check=False,
        timeout=60,
    )
    data = parse_json_output(out.stdout + out.stderr)
    if not isinstance(data, dict):
        emit("cbm_projects", status="list_failed")
        return

    projects = data.get("projects") or []
    candidates = []
    temp_prefixes = ("/tmp/", "/private/tmp/", "/var/folders/", "/private/var/folders/")
    for project in projects:
        name = project.get("name")
        root = project.get("root_path")
        if not name or not isinstance(root, str):
            continue
        if root.startswith(temp_prefixes) or not Path(root).exists():
            candidates.append(name)

    limit = int(os.environ.get("CODEX_CLEANUP_CBM_DELETE_LIMIT", "200"))
    deleted = 0
    for name in candidates[:limit]:
        if CHECK_ONLY:
            continue
        result = subprocess.run(
            [cbm_bin(), "cli", "delete_project", json.dumps({"project": name})],
            capture_output=True,
            text=True,
            check=False,
            timeout=30,
        )
        if result.returncode == 0:
            deleted += 1
    emit("cbm_projects", candidates=len(candidates), deleted=deleted, check=CHECK_ONLY)


def main():
    valid = thread_ids()
    repair_global_state(valid)
    repair_rollout_rows()
    repair_plugin_manifests()
    repair_cbm_shadow_binary()
    trim_duplicate_mcp_children()
    cleanup_stale_codex_cli_groups()
    clean_cbm_temp_projects()


if __name__ == "__main__":
    main()
